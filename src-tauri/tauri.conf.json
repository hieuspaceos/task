{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Eisenhower Task",
  "version": "0.1.0",
  "identifier": "com.eisenhower.task",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Eisenhower Task",
        "width": 1000,
        "height": 700,
        "minWidth": 700,
        "minHeight": 500,
        "center": true,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}